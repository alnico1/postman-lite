## Docker Compose / local
# Create a real .env from this file.

# Postgres (optional; defaults are set in docker-compose)
POSTGRES_DB=postman_lite
POSTGRES_USER=postman_lite
POSTGRES_PASSWORD=postman_lite_password
POSTGRES_PORT=5432

# Backend
JWT_SECRET=change_me_to_a_long_random_secret
# Use the Docker network hostname "postgres" from compose
DATABASE_URL=postgresql://postman_lite:postman_lite_password@postgres:5432/postman_lite?schema=public

# CORS
# When running via compose, the browser hits frontend on :80.
# Backend should allow the origin you load the frontend from.
CORS_ORIGIN=http://localhost

# Frontend (used at build time in Dockerfile)
VITE_API_URL=http://localhost:8080

